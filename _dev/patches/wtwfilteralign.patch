From 51bfb31e5710e1985ffa5fb31f574ba4596377e1 Mon Sep 17 00:00:00 2001
From: Claude <noreply@anthropic.com>
Date: Mon, 1 Jun 2026 00:04:52 +0000
Subject: [PATCH] fix(events): align filter-inner to page content grid

Add max-width:1280px and margin:0 auto to .filter-inner so filter
pills align to the same left/right boundaries as .wrap and
.header-inner. Fixes misalignment on viewports wider than ~1376px.
---
 events.html | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/events.html b/events.html
index f9d5e6d..60639f2 100644
--- a/events.html
+++ b/events.html
@@ -266,7 +266,8 @@ header{position:sticky;top:0;z-index:200;background:rgba(6,8,11,0.97);border-bot
 .ec-meta-item{font-size:11px;font-weight:600;letter-spacing:0.6px;color:var(--text-muted);text-transform:uppercase}
 .ec-meta-dot{display:none}
 
-/* mobile filter scroll hint — position:sticky already a containing block, no position:relative needed */
+/* filter-inner: constrain to same grid as .wrap and .header-inner */
+.filter-inner{max-width:1280px;margin:0 auto}
 .filter-bar::after{content:'';position:absolute;right:0;top:0;bottom:0;width:48px;background:linear-gradient(to right,transparent,rgba(8,11,15,0.98));pointer-events:none;z-index:1}
 @media(max-width:768px){.filter-inner{-webkit-overflow-scrolling:touch}}
 
-- 
2.43.0

