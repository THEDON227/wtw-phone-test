olor:var(--accent)">Reservation Request Received</div><div style="display:grid;gap:10px;font-size:14px;line-height:1.75;color:var(--tx)"><div><div style="font-size:9px;font-weight:900;letter-spacing:1.8px;text-transform:uppercase;color:rgba(240,237,232,.42);margin-bottom:3px">Reference</div><div>${data.reference}</div></div><div><div style="font-size:9px;font-weight:900;letter-spacing:1.8px;text-transform:uppercase;color:rgba(240,237,232,.42);margin-bottom:3px">Venue</div><div>${data.venue}</div></div><div><div style="font-size:9px;font-weight:900;letter-spacing:1.8px;text-transform:uppercase;color:rgba(240,237,232,.42);margin-bottom:3px">Date</div><div>${data.date}</div></div><div><div style="font-size:9px;font-weight:900;letter-spacing:1.8px;text-transform:uppercase;color:rgba(240,237,232,.42);margin-bottom:3px">Time</div><div>${data.time}</div></div><div><div style="font-size:9px;font-weight:900;letter-spacing:1.8px;text-transform:uppercase;color:rgba(240,237,232,.42);margin-bottom:3px">Party</div><div>${data.party}</div></div><div><div style="font-size:9px;font-weight:900;letter-spacing:1.8px;text-transform:uppercase;color:rgba(240,237,232,.42);margin-bottom:3px">Status</div><div>Under WTW Review</div></div></div><div style="border-top:1px solid rgba(255,255,255,.08);padding-top:12px;font-size:13px;line-height:1.7;color:var(--tx)">WTW is reviewing your requested time, party size, and venue fit. Your reservation is not confirmed until the venue approves availability.</div><div style="border-top:1px solid rgba(255,255,255,.08);padding-top:14px"><div style="font-size:10px;font-weight:900;letter-spacing:3px;text-transform:uppercase;color:var(--accent);margin-bottom:6px">Keeping the night going?</div><div style="font-size:13px;line-height:1.65;color:rgba(240,237,232,.68);margin-bottom:12px">Explore nearby WTW selections for after dinner.</div><a class="btn-outline" href="events.html?city=${cur}" style="display:inline-flex;align-items:center;justify-content:center;text-decoration:none">Explore After-Dinner Options</a></div></div>`}document.addEventListener("submit",async function(e){if(e.target&&e.target.id==="detailRequest"){e.preventDefault();var form=e.target;var btn=form.querySelector("button[type=submit]");var email=String(form.guestEmail&&form.guestEmail.value||"").trim();var phone=String(form.guestPhone&&form.guestPhone.value||"").trim();if(!email&&!phone){setRequestStatus("Enter an email, a phone number, or both so WTW can send your confirmation.",true);if(btn){btn.disabled=false;btn.textContent="Send Request"}return}var payload={user_name:form.guestName.value.trim(),user_email:email||"",phone:phone||"",market:cur,venue_id:null,venue_name:venue.name,requested_date:form.requestDate.value,requested_time:form.requestTime.value,party_size:parseInt(form.partySize.value,10)||1,occasion:form.occasion.value,notes:form.notes.value.trim(),status:"new"};if(btn){btn.disabled=true;btn.textContent="Sending Request..."}if(!backendReady()){setRequestStatus("WTW received your request. A concierge review will confirm availability before your night is locked in.",false);if(btn){btn.disabled=false;btn.textContent="Send Request"}return}try{var saved=await WTWBackend.createReservationRequest(payload);if(!saved||saved.success!==true) throw new Error("WTW reservation insert did not return success.");var ref=safeReservationReference(saved);var confirmation=document.getElementById("confirmationMsg");if(confirmation){confirmation.innerHTML=renderReservationConfirmation({reference:ref,venue:venue.name,date:form.requestDate.value,time:form.requestTime.value,party:parseInt(form.partySize.value,10)||1});confirmation.classList.add("show")}if(form){form.querySelectorAll("input,select,textarea,button").forEach(function(el){el.disabled=true})}if(btn){btn.disabled=true;btn.textContent="Request Received"}return}catch(err){setRequestStatus("We could not save your reservation request right now. Please try again.",true)}if(btn){btn.disabled=false;btn.textContent="Send Request"}}});applyTheme();
 document.addEventListener("keydown",function(e){if(e.key==="Escape"){var cm=document.getElementById("cityModal");if(cm)cm.classList.remove("open");var rm=document.getElementById("requestModal");if(rm)rm.classList.remove("open");var wm=document.getElementById("waitlistModal");if(wm)wm.classList.remove("open");}});</script></body></html>
