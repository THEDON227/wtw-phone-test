From 5fafce05e42638a9d5a2c3884033644d1e5471a6 Mon Sep 17 00:00:00 2001
From: Claude <noreply@anthropic.com>
Date: Mon, 1 Jun 2026 00:41:42 +0000
Subject: [PATCH] feat(events): add city signal panel to hero right column
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Two-column hero grid with glass panel showing TONIGHT IN {CITY},
event count, guest list count, and premium availability. Updates
on every city switch via 4 lines added to applyCity(). Stacks
below controls on mobile (<=900px). CSS-only layout change to
.events-hero .wrap — no existing markup restructured.
---
 events.html | 14 ++++++++++++++
 1 file changed, 14 insertions(+)

diff --git a/events.html b/events.html
index fa755f8..977726f 100644
--- a/events.html
+++ b/events.html
@@ -271,6 +271,15 @@ header{position:sticky;top:0;z-index:200;background:rgba(6,8,11,0.97);border-bot
 .filter-bar::after{content:'';position:absolute;right:0;top:0;bottom:0;width:48px;background:linear-gradient(to right,transparent,rgba(8,11,15,0.98));pointer-events:none;z-index:1}
 @media(max-width:768px){.filter-inner{-webkit-overflow-scrolling:touch}}
 
+/* city signal panel — hero right column */
+.events-hero .wrap{display:grid;grid-template-columns:1fr auto;gap:48px;align-items:start}
+@media(max-width:900px){.events-hero .wrap{grid-template-columns:1fr}}
+.city-signal{grid-column:2;grid-row:1/span 5;align-self:center;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:14px;padding:24px 28px;min-width:220px}
+@media(max-width:900px){.city-signal{grid-column:1;grid-row:auto;margin-top:20px;min-width:0}}
+.cs-eyebrow{font-size:9px;font-weight:700;letter-spacing:3px;color:var(--accent);margin-bottom:16px;text-transform:uppercase}
+.cs-stats{display:flex;flex-direction:column;gap:10px}
+.cs-stat{font-size:13px;color:var(--text-muted);font-weight:500;line-height:1.4}
+
 /* mobile featured card image height */
 @media(max-width:768px){.featured-card .fc-image img{min-height:220px}}
 
@@ -342,6 +351,7 @@ footer{padding:40px 0 32px;border-top:1px solid var(--border)}
     <div class="eh-eyebrow" id="heroEyebrow">NEW YORK · TONIGHT</div>
     <h1 class="eh-title">Events</h1>
     <p class="eh-sub">Curated tonight across rooftops, lounges, guest lists, and premium rooms.</p>
+    <div class="city-signal" id="citySignal"></div>
     <div class="eh-controls">
       <div class="search-bar">
         <span class="search-icon">⌕</span>
@@ -521,6 +531,10 @@ function applyCity(k){
       <div class="co-info"><div class="co-name" style="${k2===cur?`color:${v.p}`:''}">${v.name}</div></div>
       ${k2===cur?`<span class="co-check" style="color:${v.p}">✓</span>`:''}
     </div>`).join('');
+  const _evts=ALL_EVENTS[k]||[];
+  const _gl=_evts.filter(e=>e.glPrice===0).length;
+  const _prem=_evts.some(e=>e.vipMin>=500);
+  document.getElementById('citySignal').innerHTML=`<div class="cs-eyebrow">TONIGHT IN ${c.short}</div><div class="cs-stats"><div class="cs-stat">${_evts.length} curated nights</div><div class="cs-stat">${_gl} guest list${_gl!==1?'s':''} open</div>${_prem?'<div class="cs-stat">Premium access available</div>':''}</div>`;
   renderFeatured();
   renderGrid();
 }
-- 
2.43.0

